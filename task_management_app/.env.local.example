# Local — copy to .env.local and source before running the app
APP_ENV=local

POSTGRES_DB=task_db
POSTGRES_USER=task_user
POSTGRES_PASSWORD=task_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

DJANGO_SECRET_KEY=change-me-for-local-only
LOG_LEVEL=DEBUG
