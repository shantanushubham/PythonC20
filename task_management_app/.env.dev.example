# Dev / E2E — copy to .env.dev on the dev server
APP_ENV=dev

POSTGRES_DB=task_db
POSTGRES_USER=task_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=dev-db.internal
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://dev-redis.internal:6379/0
CELERY_RESULT_BACKEND=redis://dev-redis.internal:6379/0

DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=dev.example.com
DJANGO_DEBUG=true
LOG_LEVEL=DEBUG
