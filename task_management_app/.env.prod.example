# Production — copy to .env.prod on the prod server (never commit real values)
APP_ENV=prod

POSTGRES_DB=task_db
POSTGRES_USER=task_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=prod-db.internal
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://prod-redis.internal:6379/0
CELERY_RESULT_BACKEND=redis://prod-redis.internal:6379/0

DJANGO_SECRET_KEY=change-me-use-a-long-random-value
DJANGO_ALLOWED_HOSTS=app.example.com,api.example.com
SECURE_SSL_REDIRECT=true
LOG_LEVEL=WARNING
